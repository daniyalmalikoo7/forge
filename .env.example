# LLM Provider: "anthropic" | "openrouter" | "groq" (default: anthropic)
MODEL_PROVIDER=anthropic

# Anthropic (LLM calls via @langchain/anthropic)
ANTHROPIC_API_KEY=

# OpenRouter (alternative provider for dev/testing)
OPENROUTER_API_KEY=

# Groq (fast inference for dev/testing)
GROQ_API_KEY=

# Supabase (Postgres + pgvector + Auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Environment
NODE_ENV=development
